{
  "_comment": "ITM-067 - Portable devcontainer per ADR-11. Base image decided round 17: ghcr.io/astral-sh/uv (uv-prebuilt for fast cold start; matches ITM-033 py3.12 floor).",
  "name": "py-launch-blueprint",
  "image": "ghcr.io/astral-sh/uv:python3.12-bookworm-slim",
  "postCreateCommand": "sh .devcontainer/post-create.sh",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "tamasfe.even-better-toml",
        "EditorConfig.EditorConfig"
      ],
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",
        "python.terminal.activateEnvironment": true
      }
    }
  },
  "remoteEnv": {
    "BUN_INSTALL": "/root/.bun",
    "PATH": "/root/.bun/bin:/root/.local/bin:${containerEnv:PATH}"
  }
}
