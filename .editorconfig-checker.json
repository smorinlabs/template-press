{
  "_comment": "ITM-009. Indent rules disabled (round-9 Q&A) — Ruff/yamlfmt/taplo own indent enforcement; double-enforcement risks spurious failures. Honors *.md trim_trailing_whitespace=false from ITM-008.",
  "Verbose": false,
  "Debug": false,
  "IgnoreDefaults": false,
  "SpacesAfterTabs": false,
  "NoColor": false,
  "Exclude": [
    "\\.venv",
    "\\.git",
    "dist",
    "build",
    "node_modules",
    "uv\\.lock",
    "bun\\.lock",
    "\\.lock$",
    "docs/_build",
    "__pycache__",
    "\\.ruff_cache",
    "\\.pytest_cache",
    "\\.mypy_cache",
    "\\.ty_cache",
    "__snapshots__"
  ],
  "Disable": {
    "EndOfLine": false,
    "Indentation": true,
    "IndentSize": true,
    "InsertFinalNewline": false,
    "TrimTrailingWhitespace": false,
    "MaxLineLength": false
  }
}
